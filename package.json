{
  "name": "pi-bio-agent",
  "version": "0.1.0",
  "private": false,
  "description": "Provider-agnostic bioinformatics agent primitives, DuckDB SQL planning, and Pi coding-agent integration.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "bioinformatics",
    "genomics",
    "duckdb",
    "agentic-ai"
  ],
  "files": [
    "src",
    "dist",
    "extensions",
    "skills",
    "docs",
    "scripts",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./core": { "types": "./dist/core/index.d.ts", "import": "./dist/core/index.js" },
    "./duckdb": { "types": "./dist/duckdb/index.d.ts", "import": "./dist/duckdb/index.js" },
    "./hosts": { "types": "./dist/hosts/index.d.ts", "import": "./dist/hosts/index.js" }
  },
  "bin": {
    "pi-bio-agent": "dist/cli/bin.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "rm -rf dist-test && tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "check": "npm run typecheck && npm test && npm run check:docs && npm run check:readme && npm run check:examples",
    "docs:index": "node scripts/generate-docs-index.mjs",
    "check:docs": "node scripts/generate-docs-index.mjs --check",
    "readme": "node scripts/generate-readme.mjs",
    "check:readme": "node scripts/generate-readme.mjs --check",
    "readme:examples": "npm run build && node scripts/generate-example-readmes.mjs",
    "check:examples": "npm run build && node scripts/generate-example-readmes.mjs --check",
    "provision:duckhts": "node --input-type=module -e \"import {DuckDBInstance} from '@duckdb/node-api'; const c=await(await DuckDBInstance.create(':memory:')).connect(); await c.run('INSTALL duckhts FROM community;'); await c.run('LOAD duckhts;'); console.log('duckhts installed + loaded');\"",
    "provision:ducknng-owned": "bash scripts/provision-ducknng-owned.sh",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepare": "npm run build"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": []
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@types/node": "^24.0.0",
    "typebox": "^1.1.38",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.2-r.2"
  }
}
