{
  "name": "pi-bio-workbench",
  "version": "0.1.0",
  "private": true,
  "description": "Application workbench built on pi-bio-agent primitives; clinical genomics is the first binding.",
  "license": "GPL-2.0-or-later",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pi-bio-workbench": "dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "rm -rf dist-test && tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "check": "npm run typecheck && npm test",
    "demo:clinical": "npm run build && node dist/cli.js"
  },
  "dependencies": {
    "pi-bio-agent": "file:../pi-bio-agent"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
