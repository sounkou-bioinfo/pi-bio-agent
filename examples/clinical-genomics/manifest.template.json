{
  "schema": "pi-bio.manifest.v1",
  "id": "clinical-genomics-workbench",
  "version": "0.2.0",
  "title": "Clinical genomics workbench binding",
  "description": "Direct and inverted rare-disease evidence passes reconciled into one declared relation. This binding routes evidence; it is not a complete ACMG/AMP kernel.",
  "provides": {
    "resolvers": [
      {
        "id": "duckdb.file_scan",
        "version": "0.1.0",
        "title": "DuckDB file scan",
        "description": "Read a local file into a DuckDB table.",
        "output": { "mode": "table" }
      },
      {
        "id": "duckdb.sql_materialize",
        "version": "0.1.0",
        "title": "DuckDB SQL materialization",
        "description": "Materialize a declared read-only SQL relation.",
        "output": { "mode": "table" }
      }
    ],
    "resources": [
      {
        "id": "case_variants",
        "title": "Case variants",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/case_variants.csv", "table": "case_variants" }
      },
      {
        "id": "so_loss_of_function",
        "title": "Loss-of-function Sequence Ontology terms",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/so_loss_of_function.csv", "table": "so_loss_of_function" }
      },
      {
        "id": "case_hpo",
        "title": "Observed case HPO terms",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/case_hpo.csv", "table": "case_hpo" }
      },
      {
        "id": "gene_phenotype",
        "title": "Gene phenotype evidence",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/gene_phenotype.csv", "table": "gene_phenotype" }
      },
      {
        "id": "prior_assessment",
        "title": "Prior case assessment",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/prior_assessment.csv", "table": "prior_assessment" }
      },
      {
        "id": "assessment_status_order",
        "title": "Assessment status order",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/assessment_status_order.csv", "table": "assessment_status_order" }
      },
      {
        "id": "variant_assessment",
        "title": "Normalized variant assessment",
        "kind": "virtual",
        "resolver": "duckdb.sql_materialize",
        "params": { "table": "variant_assessment", "sqlFile": "relations/variant_assessment.sql" }
      },
      {
        "id": "phenotype_hypothesis",
        "title": "Phenotype-supported hypotheses",
        "kind": "virtual",
        "resolver": "duckdb.sql_materialize",
        "params": { "table": "phenotype_hypothesis", "sqlFile": "relations/phenotype_hypothesis.sql" }
      },
      {
        "id": "case_evidence",
        "title": "Reconciled direct and inverted case evidence",
        "kind": "virtual",
        "resolver": "duckdb.sql_materialize",
        "params": { "table": "case_evidence", "sqlFile": "relations/case_evidence.sql" }
      },
      {
        "id": "reanalysis_evidence",
        "title": "Current versus prior assessment",
        "kind": "virtual",
        "resolver": "duckdb.sql_materialize",
        "params": { "table": "reanalysis_evidence", "sqlFile": "relations/reanalysis_evidence.sql" }
      }
    ],
    "operations": [
      {
        "id": "clinical.case_evidence",
        "version": "0.2.0",
        "title": "Direct and inverted case evidence",
        "description": "Return review-bearing rows from both traversal directions over one reconciled evidence relation, preserving missingness, conflicts, abstentions, and review targets without exporting routine exclusions.",
        "transport": "duckdb.sql",
        "inputSchema": {
          "type": "object",
          "properties": { "case_id": { "type": "string" } },
          "required": ["case_id"]
        },
        "notes": [
          "Direct starts from observed variants; inverted starts from observed phenotypes.",
          "The two lanes share variant assessment semantics and retain all matching evidence-bearing variants.",
          "Missing frequency and missing genotype support remain explicit evidence rows.",
          "Routine direct-lane exclusions remain queryable in variant_assessment but are not copied into the evidence packet."
        ],
        "sql": {
          "readOnly": true,
          "requiredResources": [
            "case_variants",
            "so_loss_of_function",
            "case_hpo",
            "gene_phenotype",
            "variant_assessment",
            "phenotype_hypothesis",
            "case_evidence"
          ],
          "sqlFile": "operations/case_evidence.sql"
        }
      },
      {
        "id": "clinical.reanalysis_diff",
        "version": "0.2.0",
        "title": "Reanalysis diff",
        "description": "Compare the shared current variant assessment with a prior assessment and retain unknown status vocabularies as an abstention.",
        "transport": "duckdb.sql",
        "inputSchema": {
          "type": "object",
          "properties": { "case_id": { "type": "string" } },
          "required": ["case_id"]
        },
        "notes": [
          "Reanalysis is a delta over durable prior results, not another prompt."
        ],
        "sql": {
          "readOnly": true,
          "requiredResources": [
            "case_variants",
            "so_loss_of_function",
            "prior_assessment",
            "assessment_status_order",
            "variant_assessment",
            "reanalysis_evidence"
          ],
          "sqlFile": "operations/reanalysis_diff.sql"
        }
      }
    ]
  }
}
