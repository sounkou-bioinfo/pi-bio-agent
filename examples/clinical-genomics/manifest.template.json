{
  "schema": "pi-bio.manifest.v1",
  "id": "clinical-genomics-workbench",
  "version": "0.1.0",
  "title": "Clinical genomics workbench binding",
  "description": "Direct and inverted rare-disease evidence passes over one declared case resource set. This binding routes evidence; it is not a complete ACMG/AMP kernel.",
  "provides": {
    "resolvers": [
      {
        "id": "duckdb.file_scan",
        "version": "0.1.0",
        "title": "DuckDB file scan",
        "description": "Read a local file into a DuckDB table.",
        "output": { "mode": "table" }
      }
    ],
    "resources": [
      {
        "id": "case_variants",
        "title": "Case variants",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/case_variants.csv", "table": "case_variants" }
      },
      {
        "id": "so_loss_of_function",
        "title": "Loss-of-function Sequence Ontology terms",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/so_loss_of_function.csv", "table": "so_loss_of_function" }
      },
      {
        "id": "case_hpo",
        "title": "Observed case HPO terms",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/case_hpo.csv", "table": "case_hpo" }
      },
      {
        "id": "gene_phenotype",
        "title": "Gene phenotype curation",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/gene_phenotype.csv", "table": "gene_phenotype" }
      },
      {
        "id": "prior_assessment",
        "title": "Prior case assessment",
        "kind": "virtual",
        "resolver": "duckdb.file_scan",
        "params": { "path": "data/prior_assessment.csv", "table": "prior_assessment" }
      }
    ],
    "operations": [
      {
        "id": "clinical.direct_variant_triage",
        "version": "0.1.0",
        "title": "Direct variant-first rare-disease triage",
        "description": "Bucket observed variants into candidate, abstention, and exclusion groups. Unknown frequency is abstained, not counted as rare.",
        "transport": "duckdb.sql",
        "inputSchema": {
          "type": "object",
          "properties": { "case_id": { "type": "string" } },
          "required": ["case_id"]
        },
        "notes": [
          "Direct lane: genotype/variant first.",
          "Unknown allele frequency is abstained from, not counted as rare.",
          "Benign-annotated variants are excluded even when rare and high impact."
        ],
        "sql": {
          "readOnly": true,
          "requiredResources": ["case_variants", "so_loss_of_function"],
          "sqlFile": "operations/direct_variant_triage.sql"
        }
      },
      {
        "id": "clinical.inverted_phenotype_hypotheses",
        "version": "0.1.0",
        "title": "Inverted phenotype-first rare-disease hypotheses",
        "description": "Start from observed phenotypes, rank gene/disease hypotheses, then inspect the case genome for supporting or missing variants.",
        "transport": "duckdb.sql",
        "inputSchema": {
          "type": "object",
          "properties": { "case_id": { "type": "string" } },
          "required": ["case_id"]
        },
        "notes": [
          "Inverted lane: phenotype/disease first, then interrogate the genome.",
          "A phenotype-supported gene with no supporting variant is retained as a gap, not silently dropped."
        ],
        "sql": {
          "readOnly": true,
          "requiredResources": ["case_variants", "so_loss_of_function", "case_hpo", "gene_phenotype"],
          "sqlFile": "operations/inverted_phenotype_hypotheses.sql"
        }
      },
      {
        "id": "clinical.reanalysis_diff",
        "version": "0.1.0",
        "title": "Reanalysis diff",
        "description": "Compare the current direct-lane evidence status with a prior case status and surface new, upgraded, downgraded, unchanged, and dropped variants.",
        "transport": "duckdb.sql",
        "inputSchema": {
          "type": "object",
          "properties": { "case_id": { "type": "string" } },
          "required": ["case_id"]
        },
        "notes": [
          "Reanalysis is a delta over durable prior results, not another prompt."
        ],
        "sql": {
          "readOnly": true,
          "requiredResources": ["case_variants", "so_loss_of_function", "prior_assessment"],
          "sqlFile": "operations/reanalysis_diff.sql"
        }
      }
    ]
  }
}
